; template-version: 2026-07.27
; Supply-chain guard (pattern imported from earendil-works/pi):
; save-exact pins exact versions in package.json, making the lockfile
; the only place versions move; min-release-age makes npm resolve only
; releases at least 2 days old, defusing freshly-compromised packages.
; npm >= 12 enforces min-release-age; npm 11 prints an "Unknown project
; config" warning and ignores the key — upgrade npm, don't delete the line.
save-exact=true
min-release-age=2
